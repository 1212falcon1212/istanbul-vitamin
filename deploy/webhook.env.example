# /etc/istanbulvitamin-webhook.env
# Read by both the webhook systemd unit and (indirectly) deploy.sh.

# Required — must match the secret set in GitHub → Settings → Webhooks.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Listener bind address. CloudPanel Nginx proxies /deploy/webhook → this.
WEBHOOK_ADDR=127.0.0.1:9001

# Branch to deploy on push.
WEBHOOK_BRANCH=main

# Absolute path to deploy.sh.
DEPLOY_SCRIPT=/home/istanbulvitamin/htdocs/istanbulvitamin.com/app/deploy/deploy.sh

# Passed through to deploy.sh.
REPO_DIR=/home/istanbulvitamin/htdocs/istanbulvitamin.com/app
GO_BIN=/usr/local/go/bin/go
RUN_MIGRATIONS=true
