# Copy to /home/istanbulvitamin/htdocs/istanbulvitamin.com/app/backend/.env on the VPS.
# DO NOT commit this file with real secrets.

APP_ENV=production
APP_PORT=8090
JWT_SECRET=__change_me_to_64_random_bytes__
JWT_EXPIRY=168h

# MySQL — created via CloudPanel UI
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=istanbulvitamin
DB_USER=istanbulvitamin
DB_PASSWORD=__from_cloudpanel__

# Redis — shared host Redis, use a dedicated DB index
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=5

# Meilisearch — shared host instance on :7700
# If the existing instance has a master key, get it from another project's .env
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=__from_existing_meilisearch_instance__

# PayTR
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_BASE_URL=https://www.paytr.com

# Trendyol
TRENDYOL_SUPPLIER_ID=
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=
TRENDYOL_BASE_URL=https://api.trendyol.com/sapigw

# Hepsiburada
HB_MERCHANT_ID=
HB_USERNAME=
HB_PASSWORD=
HB_BASE_URL=https://mpop-sit.hepsiburada.com

# BizimHesap
BIZIMHESAP_API_KEY=
BIZIMHESAP_BASE_URL=https://api.bizimhesap.com

# SMTP — if using webhosting account mail, set these to Hostinger values
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=info@istanbulvitamin.com
SMTP_PASSWORD=
SMTP_FROM=info@istanbulvitamin.com

# Genel
FRONTEND_URL=https://istanbulvitamin.com
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
